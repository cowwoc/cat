{
  "guards": [
    {
      "pattern": "\\bgit\\s+rebase\\b",
      "skill": "git-rebase-agent"
    },
    {
      "pattern": "\\bgit\\s+commit\\b.*--amend\\b",
      "skill": "git-amend-agent"
    },
    {
      "pattern": "\\bgit\\s+push\\b.*--force\\b",
      "skill": "validate-git-safety-agent"
    },
    {
      "pattern": "\\brm\\s+-[a-zA-Z]*r[a-zA-Z]*",
      "skill": "safe-rm-agent"
    },
    {
      "pattern": "\\bgit\\s+filter-branch\\b",
      "skill": "git-rewrite-history-agent"
    },
    {
      "pattern": "\\bgit\\s+reset\\b.*--hard\\b",
      "skill": "validate-git-safety-agent"
    }
  ]
}
